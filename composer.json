{
    "name": "peanutgraphic/bloxy-core",
    "description": "BLOXY core PHP primitives — auth, RBAC, audit log, agent registry, suggestion layer, encrypted casts",
    "type": "library",
    "license": "MIT",
    "keywords": ["bloxy", "laravel", "inertia", "vertical-saas", "agents"],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "anthropic-ai/sdk": "^0.17",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "suggest": {
        "anthropic-ai/sdk": "Required if you bind AnthropicAgentRunner via Bloxy\\Core\\Agent\\AgentRunner. Not needed for NaiveRunner."
    },
    "autoload": {
        "psr-4": {
            "Bloxy\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bloxy\\Core\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bloxy\\Core\\BloxyCoreServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
